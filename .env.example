# Supabase 配置
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Claude Code 配置（四选一，优先级：ZHIPU > MINIMAX > QWEN > 代理）
# 模式一：智谱 GLM5 (opus对应GLM-4.7) https://docs.bigmodel.cn/cn/coding-plan/tool/claude#%E5%A6%82%E4%BD%95%E5%88%87%E6%8D%A2%E4%BD%BF%E7%94%A8%E6%A8%A1%E5%9E%8B
ZHIPU_API_KEY=
CLAUDE_MODEL=glm-5/opus/sonnet
# 模式二：MiniMax (仅支持M2.5)
MINIMAX_API_KEY=
# 模式三：通义千问 Coding Plan (通义平台支持众多模型) https://bailian.console.aliyun.com/cn-beijing/?tab=doc#/doc/?type=model&url=3005961
QWEN_API_KEY=
CLAUDE_MODEL=qwen3.5-plus/kimi-k2.5/glm-5/MiniMax-M2.5/qwen3-max-2026-01-23/qwen3-coder-next/qwen3-coder-plus/glm-4.7
# 模式四：Claude
CLAUDE_CODE_URL=https://co.yes.vg
CLAUDE_CODE_KEY=your_claude_code_key_here
CLAUDE_MODEL=opus/sonnet

# 应用外部访问地址
APP_EXTERNAL_URL=http://localhost:53781
APP_PROD_EXTERNAL_URL=http://localhost:53780

# 端口映射
CONTROL_PORT=42617
APP_BACKEND_PORT=53783
APP_FRONTEND_PORT=53781
APP_PROD_PORT=53780

# Git 配置
GIT_USER_NAME=Digital Avatar Bot
GIT_USER_EMAIL=bot@digital-avatar.local
GIT_REMOTE_URL=your_git_remote_url_here
GIT_AUTO_PUSH=true

# OpenRouter 配置（Gemini 二次结构化处理，解决格式标记丢失问题）
# 获取地址：https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=google/gemini-2.5-flash

# 鉴权（通用，作为 DEV/PROD 未设置时的回退）
AUTH_USERNAME=yourname
AUTH_PASSWORD=yourpassword

# 开发环境鉴权（NODE_ENV != production 时使用，优先级高于通用配置）
#DEV_AUTH_USERNAME=dev
#DEV_AUTH_PASSWORD=dev123

# 生产环境鉴权（NODE_ENV = production 时使用，优先级高于通用配置）
#PROD_AUTH_USERNAME=yourprodname
#PROD_AUTH_PASSWORD=yourprodpassword
