# Supabase 配置
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Claude Code 配置（四选一，优先级：ZHIPU > MINIMAX > QWEN > 代理）
# 模式一：智谱 GLM5 (opus对应GLM-4.7)
ZHIPU_API_KEY=
CLAUDE_MODEL=glm-5/opus/sonnet
# 模式二：MiniMax (仅支持M2.5)
MINIMAX_API_KEY=
# 模式三：通义千问 Coding Plan (通义平台支持众多模型)
QWEN_API_KEY=
CLAUDE_MODEL=qwen3.5-plus/other
# 模式四：Claude
CLAUDE_CODE_URL=https://co.yes.vg
CLAUDE_CODE_KEY=your_claude_code_key_here
CLAUDE_MODEL=opus/sonnet

# 应用外部访问地址
APP_EXTERNAL_URL=http://localhost:53781

# 端口映射
CONTROL_PORT=42617
APP_BACKEND_PORT=53783
APP_FRONTEND_PORT=53781

# Git 配置
GIT_USER_NAME=Digital Avatar Bot
GIT_USER_EMAIL=bot@digital-avatar.local
GIT_REMOTE_URL=your_git_remote_url_here
GIT_AUTO_PUSH=true

# 鉴权
AUTH_USERNAME=yourname
AUTH_PASSWORD=yourpassword
